# HMC-Memory Configuration
# Copy to .env and fill in values

# LLM Backend: lmstudio | ollama | claude | openai | custom
HMC_LLM_BACKEND=lmstudio

# LM Studio (default)
HMC_LMSTUDIO_URL=http://127.0.0.1:1234/v1
HMC_LMSTUDIO_MODEL=local-model

# Ollama
HMC_OLLAMA_URL=http://127.0.0.1:11434/v1
HMC_OLLAMA_MODEL=llama3

# Claude API
ANTHROPIC_API_KEY=

# OpenAI API
OPENAI_API_KEY=

# Custom LLM endpoint (OpenAI-compatible)
HMC_CUSTOM_URL=
HMC_CUSTOM_MODEL=

# Storage
HMC_DIR=~/.hmc

# Compression schedule
HMC_CHUNK_DAYS=3

# MCP server port (for status check)
HMC_MCP_PORT=4822

# Webhook server port (generic adapter)
HMC_WEBHOOK_PORT=4821
